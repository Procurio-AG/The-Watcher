# === Central Brain / AI ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Visualizer API ===
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686
GATEWAY_URL=http://localhost:8000

# === Edge Remedy ===
EVENT_BUS_URL=nats://localhost:4222
TARGET_SERVICE=payment-service
PUSHGATEWAY_URL=http://pushgateway-service:9091
K8S_NAMESPACE=train-ticket
REMEDIATION_ENABLED=false
PREDICTIVE_SCALING_ENABLED=true
CIRCUIT_BREAKER_ENABLED=false
SOFTMAX_TEMPERATURE=1.5
MAX_REPLICAS=5
REMEDIATION_COOLDOWN_MS=60000
FORECAST_INTERVAL_MS=60000
FORECAST_HORIZON_MINUTES=10
FORECAST_HISTORY_HOURS=24
FORECAST_SEASONAL_PERIOD=12
CPU_FORECAST_THRESHOLD=70
RPS_FORECAST_SPIKE_RATIO=2.0

# === Chaos Engineering (set >0 to inject failures) ===
CHAOS_LATENCY_MAX_MS=0
CHAOS_ERROR_RATE=0.0

# === OpenTelemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
